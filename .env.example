# =============================================================================
# TEMPLATE PUBLIC — Copie ce fichier en ".env" et remplis tes vraies valeurs
# =============================================================================
# Ce fichier PEUT être commité : il ne contient aucune vraie clé.
# Il sert de référence pour savoir quelles variables sont nécessaires.
# =============================================================================


# --- IA ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here


# --- Productivité & Base de données ---
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here


# --- Google ---
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here


# --- YouTube ---
YOUTUBE_API_KEY=your_youtube_data_api_key_here


# --- Déploiement ---
VERCEL_TOKEN=your_vercel_token_here


# --- Code & Versioning ---
GITHUB_TOKEN=your_github_personal_access_token_here


# --- Paiement ---
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
